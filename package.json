{
  "name": "bun-scripts",
  "type": "module",
  "private": true,
  "bin": {
    "check-env": "src/check-env/index.ts",
    "r": "src/run-package-scripts/index.ts"
  },
  "scripts": {
    "test": "bun test",
    "format": "prettier --log-level warn --write .",
    "format:check": "prettier --check .",
    "lint": "eslint src --fix",
    "lint:check": "eslint src",
    "typecheck": "tsc --noEmit",
    "verify": "bun --parallel lint format typecheck test"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@typescript-eslint/eslint-plugin": "^8.62.0",
    "@typescript-eslint/parser": "^8.62.0",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.4",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "picocolors": "^1.1.1"
  }
}
