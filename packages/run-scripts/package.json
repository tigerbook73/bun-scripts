{
  "name": "@tigerbook/run-scripts",
  "version": "0.4.0",
  "type": "module",
  "description": "Fuzzy package script selector for npm/pnpm/yarn/bun workspaces",
  "license": "MIT",
  "author": "tigerbook",
  "homepage": "https://github.com/tigerbook73/bun-scripts/tree/main/packages/run-scripts#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tigerbook73/bun-scripts.git",
    "directory": "packages/run-scripts"
  },
  "keywords": [
    "scripts",
    "npm-scripts",
    "script-runner",
    "fuzzy",
    "fuzzy-search",
    "fzf",
    "picker",
    "interactive",
    "cli",
    "monorepo",
    "workspace",
    "npm",
    "pnpm",
    "yarn",
    "bun"
  ],
  "bin": {
    "r": "src/index.ts"
  },
  "publishConfig": {
    "bin": {
      "r": "dist/index.js"
    },
    "engines": {
      "node": ">=22.0.0"
    }
  },
  "engines": {
    "bun": ">=1.0.0"
  },
  "files": [
    "dist",
    "assets"
  ],
  "scripts": {
    "build": "bun build src/index.ts --outfile dist/index.js --target node --minify && sed -i '1s|.*|#!/usr/bin/env node|' dist/index.js && chmod +x dist/index.js",
    "prepack": "bun run build",
    "test": "bun test",
    "lint": "eslint src --fix",
    "lint:check": "eslint src",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@tigerbook/settings": "workspace:*"
  },
  "dependencies": {
    "@inquirer/core": "^11.2.1",
    "@inquirer/figures": "^2.0.7",
    "@inquirer/type": "^4.0.7"
  }
}
