{
  "name": "@tigerbook/check-env",
  "version": "0.2.0",
  "type": "module",
  "description": "Validates required environment variables declared in .env.example",
  "license": "MIT",
  "author": "tigerbook",
  "repository": {
    "type": "git",
    "url": "https://github.com/tigerbook73/bun-scripts",
    "directory": "packages/check-env"
  },
  "keywords": [
    "env",
    "dotenv",
    "cli",
    "bun",
    "check-env"
  ],
  "bin": {
    "check-env": "src/index.ts"
  },
  "publishConfig": {
    "bin": {
      "check-env": "dist/index.js"
    },
    "engines": {
      "node": ">=22.0.0"
    }
  },
  "dependencies": {
    "picocolors": "^1.1.1"
  },
  "engines": {
    "bun": ">=1.0.0"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "bun build src/index.ts --outfile dist/index.js --target node && sed -i '1s|.*|#!/usr/bin/env node|' dist/index.js && chmod +x dist/index.js",
    "prepack": "bun run build",
    "test": "bun test",
    "lint": "eslint src --fix",
    "lint:check": "eslint src",
    "typecheck": "tsc --noEmit"
  }
}
