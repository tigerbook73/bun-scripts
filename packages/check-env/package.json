{
  "name": "@tigerbook/check-env",
  "version": "0.2.5",
  "type": "module",
  "description": "Validates required environment variables declared in .env.example",
  "license": "MIT",
  "author": "tigerbook",
  "homepage": "https://github.com/tigerbook73/bun-scripts/tree/main/packages/check-env#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tigerbook73/bun-scripts.git",
    "directory": "packages/check-env"
  },
  "keywords": [
    "env",
    "environment",
    "environment-variables",
    "env-vars",
    "dotenv",
    "dotenv-validator",
    "env-validation",
    "validate-env",
    "env-check",
    "config-validation",
    "configuration",
    "cli",
    "developer-tools",
    "devtools",
    "node",
    "bun",
    "typescript",
    "ci",
    "check-env"
  ],
  "bin": {
    "check-env": "src/index.ts"
  },
  "publishConfig": {
    "bin": {
      "check-env": "dist/index.js"
    },
    "engines": {
      "node": ">=22.0.0"
    }
  },
  "dependencies": {
    "picocolors": "^1.1.1"
  },
  "engines": {
    "bun": ">=1.0.0"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "bun build src/index.ts --outfile dist/index.js --target node --minify && sed -i '1s|.*|#!/usr/bin/env node|' dist/index.js && chmod +x dist/index.js",
    "prepack": "bun run build",
    "test": "bun test",
    "lint": "eslint src --fix",
    "lint:check": "eslint src",
    "typecheck": "tsc --noEmit"
  }
}
